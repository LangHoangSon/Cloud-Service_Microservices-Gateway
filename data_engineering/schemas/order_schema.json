{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order",
  "description": "Schema for a single order record — used by Order Service (write) and Databricks (read)",
  "type": "object",
  "required": ["order_id", "user_id", "status", "total_amount", "items", "created_at"],
  "properties": {
    "order_id":       { "type": "string", "format": "uuid" },
    "user_id":        { "type": "string", "format": "uuid" },
    "user_segment":   { "type": "string", "enum": ["vip", "regular", "occasional", "new"] },
    "user_city":      { "type": "string" },
    "status":         { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled"] },
    "total_amount":   { "type": "number", "minimum": 0 },
    "item_count":     { "type": "integer", "minimum": 1 },
    "payment_method": { "type": "string", "enum": ["credit_card", "debit_card", "paypal", "bank_transfer", "crypto"] },
    "year":           { "type": "integer" },
    "month":          { "type": "integer", "minimum": 1, "maximum": 12 },
    "day_of_week":    { "type": "string" },
    "created_at":     { "type": "string", "format": "date-time" },
    "updated_at":     { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["product_id", "quantity", "unit_price"],
        "properties": {
          "product_id":   { "type": "string", "format": "uuid" },
          "product_name": { "type": "string" },
          "category":     { "type": "string" },
          "quantity":     { "type": "integer", "minimum": 1 },
          "unit_price":   { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
